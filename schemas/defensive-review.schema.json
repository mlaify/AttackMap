{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://attackmap.dev/schemas/defensive-review.schema.json",
  "title": "AttackMap Defensive Review",
  "type": "object",
  "required": [
    "schema_version",
    "target_metadata",
    "system_overview",
    "attack_surface",
    "strengths",
    "weaknesses_risk_hotspots",
    "evidence_chains",
    "recommendations",
    "raw_structured_signals",
    "limitations_meta"
  ],
  "properties": {
    "schema_version": {
      "type": "string"
    },
    "target_metadata": {
      "type": "object"
    },
    "system_overview": {
      "type": "object"
    },
    "attack_surface": {
      "type": "object"
    },
    "assets": {
      "type": "array",
      "description": "Inferred high-value assets and their locations.",
      "items": { "type": "object" }
    },
    "controls": {
      "type": "array",
      "description": "Defensive controls observed in code and expected-but-absent controls.",
      "items": { "type": "object" }
    },
    "notable_observations": {
      "type": "array",
      "description": "Cross-cutting insights connecting assets, controls, surfaces, and chains.",
      "items": { "type": "object" }
    },
    "detection_opportunities": {
      "type": "array",
      "description": "Defender-facing detection-engineering hints derived from insights and findings.",
      "items": { "type": "object" }
    },
    "attack_techniques_observed": {
      "type": "array",
      "description": "Deduplicated MITRE ATT&CK techniques observed across findings and insights.",
      "items": { "type": "object" }
    },
    "strengths": {
      "type": "array"
    },
    "weaknesses_risk_hotspots": {
      "type": "object"
    },
    "evidence_chains": {
      "type": "array"
    },
    "recommendations": {
      "type": "array"
    },
    "raw_structured_signals": {
      "type": "object"
    },
    "limitations_meta": {
      "type": "object"
    }
  },
  "additionalProperties": true
}
